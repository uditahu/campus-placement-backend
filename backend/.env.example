# ── Server ────────────────────────────────
PORT=5000
SESSION_SECRET=change_this_secret_key

# ── MySQL (AWS RDS) ───────────────────────
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_USER=admin
DB_PASSWORD=your_db_password
DB_NAME=campus_db

# ── AWS S3 ────────────────────────────────
S3_BUCKET=campus-resumes-uditahuja
AWS_REGION=ap-south-1
# Leave blank on EC2 — IAM role handles auth
# Fill in for local development only:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Frontend URL (CORS) ───────────────────
# Local:
FRONTEND_URL=http://localhost:5173
# Production: (uncomment and update)
# FRONTEND_URL=http://13.234.82.22
